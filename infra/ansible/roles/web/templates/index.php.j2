<?php
$db_host = "{{ db_endpoint }}";
$db_user = "{{ db_user }}";
$db_pass = "{{ db_password }}";
$db_name = "{{ db_name }}";

$conn = @new mysqli($db_host, $db_user, $db_pass, $db_name);
?>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>TodoApp Infra Check</title>
</head>
<body>
  <h1>TodoApp Web Server: <?php echo gethostname(); ?></h1>
  <?php if ($conn && !$conn->connect_error): ?>
    <p>DB status: connected to <?php echo htmlspecialchars($db_host); ?></p>
  <?php else: ?>
    <p>DB status: connection failed</p>
  <?php endif; ?>
</body>
</html>

