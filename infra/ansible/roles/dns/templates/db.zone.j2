$TTL 300
@   IN  SOA ns1.{{ dns_zone_name }}. admin.{{ dns_zone_name }}. (
        2026022301
        3600
        1800
        604800
        300
)
@       IN NS  ns1.{{ dns_zone_name }}.
ns1     IN A   {{ ansible_host | default(inventory_hostname) }}
{% for rec in dns_records | default([]) %}
{{ rec.name }} IN A {{ rec.ip }}
{% endfor %}

