global
    log         127.0.0.1 local2
    chroot      /var/lib/haproxy
    pidfile     /var/run/haproxy.pid
    maxconn     4000
    user        haproxy
    group       haproxy
    daemon

defaults
    mode                    http
    log                     global
    option                  httplog
    option                  dontlognull
    retries                 3
    timeout connect         10s
    timeout client          1m
    timeout server          1m

frontend web_front
    bind *:80
    default_backend web_servers

backend web_servers
    balance     roundrobin
    server web1 192.0.2.11:80 check
    server web2 192.0.2.12:80 check
