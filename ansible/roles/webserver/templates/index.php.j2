<?php
// 4단계: DB 로드밸런서(lbdb1)를 통해 연결
$host     = "{{ db_lb_host }}";
$port     = {{ db_port }};
$dbname   = "{{ db_name }}";
$username = "{{ db_user }}";
$password = "{{ db_password }}";

$dsn  = "pgsql:host=$host;port=$port;dbname=$dbname";
try {
    $pdo = new PDO($dsn, $username, $password);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
} catch (PDOException $e) {
    die("<h2>DB 연결 실패: " . $e->getMessage() . "</h2>");
}

echo "<h1>DB 연결 성공! (via DB LoadBalancer)</h1>";
echo "<h2>{{ db_table }} 데이터</h2>";

$stmt = $pdo->query("SELECT * FROM {{ db_table }}");
echo "<table border='1' cellpadding='8'>";
echo "<tr><th>ID</th><th>Name</th></tr>";
while ($row = $stmt->fetch(PDO::FETCH_ASSOC)) {
    echo "<tr><td>" . htmlspecialchars((string)$row['id']) . "</td><td>" . htmlspecialchars((string)$row['name']) . "</td></tr>";
}
echo "</table>";
?>
